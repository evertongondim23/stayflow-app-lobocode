# Copie para .env e preencha. docker/ só referencia estas chaves.

# --- Build Vite (obrigatório) — URL pública da API Time da Sorte ---
VITE_API_URL=https://timedasorte-api.lobocode.com.br

# --- Frontend na VPS (docker-compose.vps-app.yml) ---
COMPOSE_VPS_STACK_NAME=timedasorte-app-vps
FRONTEND_CONTAINER_NAME=timedasorte-app
FRONTEND_CONTAINER_PORT=80
VPS_APP_PROJECT_NAME=timedasorte-app
APP_HOST=timedasorte-app.lobocode.com.br
VPS_APP_COMPOSE_FILE=docker/docker-compose.vps-app.yml
APP_HOST_EXAMPLE=timedasorte-app.lobocode.com.br

# Labels Traefik — iguais ao gateway (subido no repo da API / infra)
TRAEFIK_NETWORK=reverse-proxy
TRAEFIK_CERT_RESOLVER=letsencrypt
